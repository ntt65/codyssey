# 1. 베이스 이미지 선택 (Nginx 사용 예시)
FROM nginx:stable-alpine

# 2. 호스트의 app 폴더 안의 내용을 컨테이너의 nginx 경로로 복사
# (현재 위치가 프로젝트 루트이므로 ./app/ 경로를 사용합니다)
COPY ./app /usr/share/nginx/html/

# 3. 80번 포트 개방 알림
EXPOSE 80
#  EXPOSE 80의 진짜 역할
# 많은 분이 오해하시는데, 이 명령어는 실제로 포트를 열어주는(Open) 기능이라기보다는 
# **"이 컨테이너는 80번 포트를 사용하도록 설계되었습니다"**라고 알려주는 설명서(주석) 같은 역할입니다.
# 실제로 80번 포트를 통해 웹사이트에 접속하려면, 나중에 실행할 때 -p 8080:80 같은 옵션을 줘야 합니다.